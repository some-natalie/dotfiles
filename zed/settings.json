// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To sele all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  // copilot
  "indent_guides": {
    "background_coloring": "indent_aware",
  },
  "outline_panel": {
    "default_width": 300.0,
    "dock": "right",
  },
  "collaboration_panel": {
    "default_width": 300.0,
    "button": false,
    "dock": "right",
  },
  "git_panel": {
    "default_width": 300.0,
    "dock": "right",
    "tree_view": true,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "allow_all": "off",
      },
      "type": "registry",
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["plan"],
      },
      "type": "registry",
      "env": {
        "CLAUDE_CODE_USE_BEDROCK": "1",
        "AWS_PROFILE": "",
        "AWS_REGION": "",
        "AWS_ENDPOINT_URL_BEDROCK_RUNTIME": "",
        "AWS_ENDPOINT_URL_BEDROCK": "",
        "ANTHROPIC_BEDROCK_BASE_URL": "",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "",
      },
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "title_bar": {
    "show_menus": false,
  },
  "git": {
    "inline_blame": {
      "padding": 7,
    },
  },
  "calls": {
    "mute_on_join": true,
  },
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [],
    "mode": "subtle",
    "copilot": {
      "enable_next_edit_suggestions": true,
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
  },
  "show_edit_predictions": true,
  "languages": {
    "Markdown": {
      "show_edit_predictions": false,
      "remove_trailing_whitespace_on_save": true,
      "show_whitespaces": "all",
      "show_completions_on_input": false,
    },
    "JSON": {
      "formatter": "prettier",
    },
  },
  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "single_file_review": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.5",
    },
    "enabled": true,
  },
  // fonts
  "ui_font_size": 16,
  "ui_font_family": "Inconsolata",
  "buffer_font_size": 18,
  "buffer_font_family": "Inconsolata",
  // updates
  "auto_update": true,
  // theme
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
    // "light": "Rosé Pine Dawn",
    // "dark": "Rosé Pine Moon"
    // "light": "One Light",
    // "dark": "One Dark"
  },
  "icon_theme": {
    "dark": "Catppuccin Macchiato",
    "light": "Catppuccin Latte",
    "mode": "system",
  },
  // editor
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "remove_trailing_whitespace_on_save": true,
  "show_whitespaces": "all",
  "project_panel": {
    "default_width": 300.0,
    "dock": "right",
    "hide_gitignore": false,
    "auto_reveal_entries": false,
  },
  // terminal
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "detect_venv": "off",
    // "detect_venv": {
    //   "on": {
    //     "directories": [" .env", "env", ".venv", "venv"],
    //     "activate_script": "default",
    //   },
    // },
    "working_directory": {
      "always": {
        "directory": "/Users/natalie.somersall",
      },
    },
    "font_size": 16,
    "font_family": "Inconsolata",
    "copy_on_select": true,
    "shell": "system",
  },
}
